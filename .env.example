# Runtime
NODE_ENV=development
LOG_LEVEL=info
CRON_SCHEDULE=0 * * * *
RUN_ON_START=true
EXIT_AFTER_RUN=false
DRY_RUN=false
MAX_ITEM_AGE_HOURS=48

# Storage
SEEN_STORE_PATH=storage/seen-news.json

# Gmail SMTP email alerts
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=mgrvijay97@gmail.com
SMTP_PASS=lsvz jdzd otsz lzzj
EMAIL_FROM="AI News Agent <mgrvijay97@gmail.com>"
EMAIL_TO=mgrvijay97@gmail.com

# Official AI news feeds
OFFICIAL_FEEDS_ENABLED=true

# Optional Reddit monitoring, free and disabled by default.
REDDIT_ENABLED=false
REDDIT_QUERY=(OpenAI OR Anthropic OR Gemini OR DeepMind OR "Meta AI" OR Mistral OR xAI OR Grok OR "Hugging Face" OR Cohere OR Perplexity)
REDDIT_LIMIT=10

# Optional Hacker News monitoring, free and disabled by default.
HN_ENABLED=false
HN_QUERY=OpenAI Anthropic Gemini DeepMind Mistral xAI Grok Llama Hugging Face
HN_LIMIT=20

# Optional Telegram notifications, free and disabled by default.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional AI summaries.
# Kept off by default to avoid paid APIs. The app uses free extractive summaries without this.
AI_SUMMARIES_ENABLED=false
ANTHROPIC_API_KEY=

# Keyword relevance filter — removes non-model/agent news before sending.
RELEVANCE_FILTER_ENABLED=true
RELEVANCE_MIN_SCORE=0.5

# Auto-prune seen IDs older than this many days to keep storage/seen-news.json lean.
SEEN_MAX_AGE_DAYS=60
